{
  "expo": {
    "name": "Stravio",
    "slug": "stravio",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./apps/mobile/assets/icon.png",
    "scheme": "stravio",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bhmt3wp.stravio",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Daily workout reminders to help you stay consistent."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.bhmt3wp.stravio",
      "permissions": ["android.permission.SCHEDULE_EXACT_ALARM", "android.permission.VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./apps/mobile/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "409a6cbe-3f04-4863-9dd3-7d614ec338ef"
      }
    },
    "owner": "stravio"
  }
}
